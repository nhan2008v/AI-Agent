# LLM Providers
OPENAI_API_KEY=
OPENAI_BASE_URL=
ANTHROPIC_API_KEY=sk-ant-...
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o

# LangSmith Observability (optional)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=agentic_data_cleaner

# Database (PostgreSQL for LangGraph checkpointing)
POSTGRES_URL=postgresql://user:password@localhost:5432/agentic_data_cleaner_db

# Redis (for session store and job queue)
REDIS_URL=redis://localhost:6379/0

# API
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change-me-in-production
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173", "http://127.0.0.1:5173"]

# Storage
UPLOAD_DIR=/tmp/agentic-data-cleaner/uploads
OUTPUT_DIR=/tmp/agentic-data-cleaner/outputs
MAX_FILE_SIZE_MB=50

# Pipeline Config
MAX_CONCURRENT_PIPELINES=10
HITL_TIMEOUT_SECONDS=300
WORKER_CONCURRENCY=4
